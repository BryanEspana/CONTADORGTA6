---
import '../styles/global.css';
import Countdown from '../components/Countdown.tsx';
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/img/gta6-logo.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="generator" content={Astro.generator} />
    <title>GTA VI Countdown</title>
    <meta name="theme-color" content="#d946ef" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/img/gta6-icon-square.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@900&display=swap" rel="stylesheet">
  </head>
  <body class="bg-black text-white h-[100dvh] w-full overflow-hidden relative font-['Inter',sans-serif] select-none">
    
    <!-- Imagen de fondo (Fallback / Base) -->
    <div class="absolute inset-0 z-0 bg-[url('/img/Vice_City_01.jpg')] bg-cover bg-center bg-no-repeat opacity-40"></div>

    <!-- Video de fondo (sin loop, se detiene en el último frame) -->
    <video 
      autoplay 
      muted 
      playsinline 
      class="absolute inset-0 w-full h-full object-cover z-0 opacity-60"
    >
      <source src="/img/landscape_cover_art.mp4" type="video/mp4" />
    </video>

    <!-- Overlay oscuro ultra contrastado para garantizar lectura perfecta -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/90 via-black/60 to-black/95 z-0"></div>
    <div class="absolute inset-0 bg-black/30 z-0 pointer-events-none"></div>

    <!-- Efecto de neblina (Fog) animado -->
    <div class="pointer-events-none absolute -inset-[100%] animate-[spin_60s_linear_infinite] opacity-30 mix-blend-screen z-10">
      <div class="absolute top-1/4 left-1/4 w-[80vw] h-[80vw] rounded-full bg-fuchsia-600 blur-[150px] opacity-20"></div>
      <div class="absolute bottom-1/4 right-1/4 w-[80vw] h-[80vw] rounded-full bg-cyan-600 blur-[150px] opacity-20"></div>
    </div>
    
    <!-- Ruido / Granulado estático (Noise) -->
    <div class="pointer-events-none absolute inset-0 opacity-[0.03] z-10" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
    
    <main class="relative z-20 w-full h-full flex flex-col items-center justify-center">
      <Countdown client:load />
    </main>
    
  </body>
</html>
